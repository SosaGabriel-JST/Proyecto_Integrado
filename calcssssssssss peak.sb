Controls.SetSize(b45, 60, 32)
b46 = Controls.AddButton("x^-1", 220, 450)
Controls.SetSize(b46, 70, 32)

' VARIABLES
OPplus = 0
OPMinus = 0
OPmultiply = 0
OPdivide = 0
firstNum = 0
Ans = 0
Memory = 0

Controls.ButtonClicked = Button

Sub Button

  Last_Button = Controls.LastClickedButton

  ' NUMBERS
  If Last_Button = b25 Then
    appendVal = "7"
    AppendText()

  ElseIf Last_Button = b26 Then
    appendVal = "8"
    AppendText()

  ElseIf Last_Button = b27 Then
    appendVal = "9"
    AppendText()

  ElseIf Last_Button = b29 Then
    appendVal = "4"
    AppendText()

  ElseIf Last_Button = b30 Then
    appendVal = "5"
    AppendText()

  ElseIf Last_Button = b31 Then
    appendVal = "6"
    AppendText()

  ElseIf Last_Button = b33 Then
    appendVal = "1"
    AppendText()

  ElseIf Last_Button = b34 Then
    appendVal = "2"
    AppendText()

  ElseIf Last_Button = b35 Then
    appendVal = "3"
    AppendText()

  ElseIf Last_Button = b37 Then
    appendVal = "0"
    AppendText()

  ElseIf Last_Button = b38 Then
    appendVal = "."
    AppendText()

  ' OPERATORS
  ElseIf Last_Button = b40 Then
    ButtonPlus()

  ElseIf Last_Button = b43 Then
    ButtonMinus()

  ElseIf Last_Button = b32 Then
    ButtonMultiply()

  ElseIf Last_Button = b36 Then
    ButtonDivide()

  ElseIf Last_Button = b42 Then
    ButtonEquals()

  ' CLEAR
  ElseIf Last_Button = b44 Then
    ButtonAC()

  ' DELETE
  ElseIf Last_Button = b28 Then
    ButtonDEL()

  ' ANSWER
  ElseIf Last_Button = b41 Then
    appendVal = Ans
    AppendText()

  ' PI
  ElseIf Last_Button = b20 Then
    appendVal = Math.Pi
    AppendText()

  ' E
  ElseIf Last_Button = b45 Then
    appendVal = "2.718281828"
    AppendText()

  ' SQRT
  ElseIf Last_Button = b9 Then
    ButtonSqrt()

  ' SQUARE
  ElseIf Last_Button = b10 Then
    ButtonSquare()

  ' INVERSE
  ElseIf Last_Button = b7 Or Last_Button = b46 Then
    ButtonInverse()

  ' SIN
  ElseIf Last_Button = b15 Then
    ButtonSin()

  ' COS
  ElseIf Last_Button = b16 Then
    ButtonCos()

  ' TAN
  ElseIf Last_Button = b17 Then
    ButtonTan()

  EndIf

EndSub

Sub AppendText
  current = Controls.GetTextBoxText(Box)
  Controls.SetTextBoxText(Box, current + appendVal)
EndSub

Sub ButtonPlus
  firstNum = Controls.GetTextBoxText(Box)
  OPplus = 1
  OPMinus = 0
  OPmultiply = 0
  OPdivide = 0
  Controls.SetTextBoxText(Box, "")
EndSub

Sub ButtonMinus
  firstNum = Controls.GetTextBoxText(Box)
  OPplus = 0
  OPMinus = 1
  OPmultiply = 0
  OPdivide = 0
  Controls.SetTextBoxText(Box, "")
EndSub

Sub ButtonMultiply
  firstNum = Controls.GetTextBoxText(Box)
  OPplus = 0
  OPMinus = 0
  OPmultiply = 1
  OPdivide = 0
  Controls.SetTextBoxText(Box, "")
EndSub

Sub ButtonDivide
  firstNum = Controls.GetTextBoxText(Box)
  OPplus = 0
  OPMinus = 0
  OPmultiply = 0
  OPdivide = 1
  Controls.SetTextBoxText(Box, "")
EndSub

Sub ButtonEquals

  secondNum = Controls.GetTextBoxText(Box)

  If OPplus = 1 Then
    result = firstNum + secondNum
  ElseIf OPMinus = 1 Then
    result = firstNum - secondNum
  ElseIf OPmultiply = 1 Then
    result = firstNum * secondNum
  ElseIf OPdivide = 1 Then
    If secondNum = 0 Then
      result = "Error"
    Else
      result = firstNum / secondNum
    EndIf
  EndIf

  Ans = result
  Controls.SetTextBoxText(Box, result)

EndSub

Sub ButtonAC
  Controls.SetTextBoxText(Box, "")
EndSub

Sub ButtonDEL
  current = Controls.GetTextBoxText(Box)
  length = Text.GetLength(current)

  If length > 0 Then
    current = Text.GetSubText(current, 1, length - 1)
    Controls.SetTextBoxText(Box, current)
  EndIf
EndSub

Sub ButtonSqrt
  current = Controls.GetTextBoxText(Box)

  If current <> "" Then
    result = Math.SquareRoot(current)
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub

Sub ButtonSquare
  current = Controls.GetTextBoxText(Box)

  If current <> "" Then
 result = current * current
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub

Sub ButtonInverse
  current = Controls.GetTextBoxText(Box)

  If current <> "0" And current <> "" Then
    result = 1 / current
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub

Sub ButtonSin
  current = Controls.GetTextBoxText(Box)

  If current <> "" Then
    radians = current * Math.Pi / 180
    result = Math.Sin(radians)
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub

Sub ButtonCos
  current = Controls.GetTextBoxText(Box)

  If current <> "" Then
    radians = current * Math.Pi / 180
    result = Math.Cos(radians)
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub

Sub ButtonTan
  current = Controls.GetTextBoxText(Box)

  If current <> "" Then
    radians = current * Math.Pi / 180
    result = Math.Tan(radians)
    Ans = result
    Controls.SetTextBoxText(Box, result)
  EndIf
EndSub