' Window Format
GraphicsWindow.Width = 315
GraphicsWindow.Height = 600
GraphicsWindow.BackgroundColor = "Gray"
GraphicsWindow.CanResize = "False"
GraphicsWindow.Title = "Calculator"

' Outer border
GraphicsWindow.PenColor = "Black"
GraphicsWindow.DrawRectangle(5, 5, 305, 590)

' Display area
Box = Controls.AddTextBox(20, 20)
Controls.SetSize(Box, 275, 45)

' Keyboard area
GraphicsWindow.BrushColor = "Gray"
GraphicsWindow.FillRectangle(20, 75, 275, 510)
GraphicsWindow.DrawRectangle(20, 75, 275, 510)

